    "official_example": "Title: 产线负荷热力分布矩阵\nColorPalette: sunset\n\nSpec: {\n  \"type\": \"heatmap\",\n  \"data\": [{ \"values\": [\n    {\"hour\":\"08:00\",\"line\":\"L1\",\"v\":90}, {\"hour\":\"09:00\",\"line\":\"L1\",\"v\":95},\n    {\"hour\":\"08:00\",\"line\":\"L2\",\"v\":40}, {\"hour\":\"09:00\",\"line\":\"L2\",\"v\":50}\n  ]}],\n  \"xField\": \"hour\", \"yField\": \"line\", \"valueField\": \"v\",\n  \"label\": { \"visible\": true },\n  \"axes\": [\n    { \"orient\": \"bottom\", \"label\": { \"visible\": true } },\n    { \"orient\": \"left\", \"label\": { \"visible\": true } }\n  ]\n}",
