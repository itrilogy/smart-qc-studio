    "official_example": "Title: 品质缺陷项相关性矩阵分析\nColorPalette: sunset\nShowLabel: true\n\nSpec: {\n  \"type\": \"heatmap\",\n  \"data\": [{ \"values\": [\n    {\"x\":\"划伤\",\"y\":\"开裂\",\"v\":0.85}, {\"x\":\"划伤\",\"y\":\"变形\",\"v\":0.20},\n    {\"x\":\"开裂\",\"y\":\"划伤\",\"v\":0.85}, {\"x\":\"开裂\",\"y\":\"变形\",\"v\":0.15}\n  ]}],\n  \"xField\": \"x\", \"yField\": \"y\", \"valueField\": \"v\",\n  \"label\": { \"visible\": true },\n  \"axes\": [{ \"orient\": \"bottom\" }, { \"orient\": \"left\" }]\n}",
